#!/usr/bin/env bash

# backup - copy current VS Code user keybindings and settings into this
# repository.
#
# Usage:
#   ./backup
#
# The script writes to ./User relative to the script location.

set -euo pipefail

case "$(uname)" in
    Darwin)
        USERDATA="$HOME/Library/Application Support/Code"
        ;;
    Linux)
        if [[ -n "${XDG_CONFIG_HOME:-}" ]]; then
            USERDATA="$XDG_CONFIG_HOME/Code"
        else
            USERDATA="$HOME/.config/Code"
        fi
        ;;
    CYGWIN*|MINGW*|MSYS*)
        USERDATA="$APPDATA/Code"
        ;;
    *)
        echo "warning: unknown platform '$(uname)', using ~/.config/Code" >&2
        USERDATA="$HOME/.config/Code"
        ;;
esac

DEST_DIR="$(dirname "$0")/User"
mkdir -p "$DEST_DIR"

FILES=(keybindings.json settings.json)

for filename in "${FILES[@]}"; do
    SRC="$USERDATA/User/$filename"
    DEST="$DEST_DIR/$filename"

    if [[ ! -f "$SRC" ]]; then
        echo "warning: source file '$SRC' does not exist; skipping" >&2
        continue
    fi

    cp -a "$SRC" "$DEST"
    echo "backed up $filename to $DEST"
done

echo "backup complete"